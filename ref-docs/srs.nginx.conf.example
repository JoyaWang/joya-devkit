server {
    listen 443 ssl;
    listen [::]:443 ssl;
    server_name srs.infinex.cn dl-dev.infinex.cn dl.infinex.cn;

    ssl_certificate /etc/letsencrypt/live/infinex.cn/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/infinex.cn/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    set $srs_upstream_host $host;
    if ($http_tencent_acceleration_domain_name != "") {
        set $srs_upstream_host $http_tencent_acceleration_domain_name;
    }

    location / {
        proxy_pass http://127.0.0.1:3010;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $srs_upstream_host;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Original-Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Tencent-Acceleration-Domain-Name $http_tencent_acceleration_domain_name;
        proxy_cache_bypass $http_upgrade;
        proxy_connect_timeout 60s;
        proxy_send_timeout 60s;
        proxy_read_timeout 60s;
        client_max_body_size 32m;
    }
}

server {
    listen 80;
    listen [::]:80;
    server_name srs.infinex.cn dl-dev.infinex.cn dl.infinex.cn;

    return 301 https://$host$request_uri;
}
