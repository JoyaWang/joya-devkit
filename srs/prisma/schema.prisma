generator client {
  provider = "prisma-client"
  output   = "../apps/api/src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Object {
  id              String                  @id @default(cuid())
  projectKey      String                  @map("project_key")
  env             String
  domain          String
  scope           String
  entityId        String                  @map("entity_id")
  fileKind        String                  @map("file_kind")
  objectKey       String                  @unique @map("object_key")
  fileName        String                  @map("file_name")
  contentType     String                  @map("content_type")
  size            Int
  checksum        String?
  visibility      String                  @default("private")
  objectProfile   String?                 @map("object_profile")
  accessClass     String?                 @map("access_class")
  uploaderType    String                  @map("uploader_type")
  uploaderId      String                  @map("uploader_id")
  status          String                  @default("pending_upload")
  purpose         String?
  createdAt       DateTime                @default(now()) @map("created_at")
  deletedAt       DateTime?               @map("deleted_at")
  storageLocations ObjectStorageLocation[]

  @@map("objects")
}

model AppRelease {
  id                 String   @id @default(cuid())
  projectKey         String   @map("project_key")
  platform           String
  env                String
  appVersion         String   @map("app_version")
  buildNumber        Int      @map("build_number")
  semanticVersion    String   @map("semantic_version")
  distributionTarget String   @map("distribution_target")
  distributionUrl    String   @map("distribution_url")
  artifactObjectKey  String?  @map("artifact_object_key")
  releaseNotes       String?  @map("release_notes")
  changelog          String?
  forceUpdate        Boolean  @default(false) @map("force_update")
  minSupportedVersion String? @map("min_supported_version")
  rolloutStatus      String   @default("draft") @map("rollout_status")
  rolloutPercent     Int      @default(100) @map("rollout_percent")
  createdBy          String   @map("created_by")
  createdAt          DateTime @default(now()) @map("created_at")

  @@map("app_releases")
}

model ReleaseChannel {
  id             String   @id @default(cuid())
  projectKey     String   @map("project_key")
  platform       String
  env            String
  channel        String
  activeReleaseId String? @map("active_release_id")

  @@unique([projectKey, platform, env, channel])
  @@map("release_channels")
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  actorType String   @map("actor_type")
  actorId   String   @map("actor_id")
  resource  String
  detail    String?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("audit_logs")
}

model ProjectManifest {
  id          String   @id @default(cuid())
  projectKey  String   @unique @map("project_key")
  displayName String   @map("display_name")
  status      String   @default("active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("project_manifests")
}

model ProjectServiceBinding {
  id               String                @id @default(cuid())
  projectKey       String                @map("project_key")
  runtimeEnv       String                @map("runtime_env")
  serviceType      String                @map("service_type")
  provider         String
  config           String
  createdAt        DateTime              @default(now()) @map("created_at")
  updatedAt        DateTime              @updatedAt @map("updated_at")
  sourceMigrations StorageMigrationJob[] @relation("SourceBindingMigrations")
  targetMigrations StorageMigrationJob[] @relation("TargetBindingMigrations")
  storageLocations ObjectStorageLocation[]

  @@unique([projectKey, runtimeEnv, serviceType])
  @@map("project_service_bindings")
}

model ObjectStorageLocation {
  id                 String                @id @default(cuid())
  objectId           String                @map("object_id")
  bindingId          String                @map("binding_id")
  provider           String
  locationRole       String                @map("location_role")
  status             String                @default("active")
  checksumVerifiedAt DateTime?             @map("checksum_verified_at")
  lastHeadAt         DateTime?             @map("last_head_at")
  createdAt          DateTime              @default(now()) @map("created_at")
  updatedAt          DateTime              @updatedAt @map("updated_at")
  object             Object                @relation(fields: [objectId], references: [id])
  binding            ProjectServiceBinding @relation(fields: [bindingId], references: [id])

  @@index([objectId, locationRole])
  @@map("object_storage_locations")
}

model StorageMigrationJob {
  id              String                @id @default(cuid())
  projectKey      String                @map("project_key")
  runtimeEnv      String                @map("runtime_env")
  serviceType     String                @map("service_type")
  sourceBindingId String                @map("source_binding_id")
  targetBindingId String                @map("target_binding_id")
  selector        String?
  status          String                @default("pending")
  detail          String?
  createdAt       DateTime              @default(now()) @map("created_at")
  updatedAt       DateTime              @updatedAt @map("updated_at")
  sourceBinding   ProjectServiceBinding @relation("SourceBindingMigrations", fields: [sourceBindingId], references: [id])
  targetBinding   ProjectServiceBinding @relation("TargetBindingMigrations", fields: [targetBindingId], references: [id])

  @@index([projectKey, runtimeEnv, serviceType, status])
  @@map("storage_migration_jobs")
}

model FeedbackSubmission {
  id                String    @id @default(cuid())
  projectKey        String    @map("project_key")
  type              String
  errorMessage      String?   @map("error_message")
  errorType         String?   @map("error_type")
  stackTrace        String?   @map("stack_trace")
  source            String?
  logs              String?
  deviceInfo        String?   @map("device_info")
  userId            String?   @map("user_id")
  username          String?
  currentRoute      String?   @map("current_route")
  appVersion        String?   @map("app_version")
  buildNumber       String?   @map("build_number")
  githubIssueUrl    String?   @map("github_issue_url")
  githubIssueNumber Int?      @map("github_issue_number")
  status            String    @default("pending")
  createdAt         DateTime  @default(now()) @map("created_at")

  @@index([projectKey, type, createdAt])
  @@index([projectKey, status])
  @@map("feedback_submissions")
}

model FeedbackClientSettings {
  id                    String   @id @default(cuid())
  projectKey            String   @unique @map("project_key")
  errorReportingEnabled Boolean  @default(true) @map("error_reporting_enabled")
  crashReportingEnabled Boolean  @default(true) @map("crash_reporting_enabled")
  updatedAt             DateTime @updatedAt @map("updated_at")

  @@map("feedback_client_settings")
}
