# Shared Runtime Services - Environment Variables
# Copy to .env and fill in values

NODE_ENV=development
PORT=3000

# PostgreSQL
DATABASE_URL=postgres://srs:srs@localhost:5432/srs

# Redis
REDIS_URL=redis://localhost:6379

# Auth — token to projectKey mapping
# Format: token1=projectKey1,token2=projectKey2,...
# Each registered project needs a token mapping here.
# NOTE: Adding a token here does NOT register the project.
#       Projects must be registered via seed script or admin-platform.
SERVICE_TOKENS=dev-token-infov=infov,dev-token-laicai=laicai,dev-token-unbound=unbound,dev-token-ghost=ghost

# Object Storage (COS) — LEGACY FALLBACK ONLY
# These env vars are no longer the formal long-term architecture.
# Object storage is now driven by project-level bindings in the database.
# COS_* env vars are retained only for backward-compatible fallback
# when no explicit config is provided.
# COS_SECRET_ID=
# COS_SECRET_KEY=
# COS_BUCKET=
# COS_REGION=
# COS_SIGN_EXPIRES_SECONDS=900

# Per-project COS config (used by seed-projects.ts)
# INFOV_COS_BUCKET=
# INFOV_COS_REGION=
# INFOV_COS_SECRET_ID=
# INFOV_COS_SECRET_KEY=
# LAICAI_COS_BUCKET=
# LAICAI_COS_REGION=
# LAICAI_COS_SECRET_ID=
# LAICAI_COS_SECRET_KEY=
