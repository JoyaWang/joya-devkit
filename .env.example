# Shared Runtime Services - Environment Variables
# Copy to .env and fill in values

NODE_ENV=development
PORT=3000

# PostgreSQL
DATABASE_URL=postgres://srs:srs@localhost:5432/srs

# Redis
REDIS_URL=redis://localhost:6379

# Auth — token to projectKey:runtimeEnv mapping
# Format: token1=projectKey1:runtimeEnv1,token2=projectKey2:runtimeEnv2,...
# Each registered project environment needs a token mapping here.
# NOTE: Adding a token here does NOT register the project.
#       Projects and per-environment bindings must be registered via seed script or admin-platform.
SERVICE_TOKENS=dev-token-infov=infov:dev,prd-token-infov=infov:prd,dev-token-laicai=laicai:dev,prd-token-laicai=laicai:prd,dev-token-unbound=unbound:dev,dev-token-ghost=ghost:dev

# Object Storage (COS) — LEGACY FALLBACK ONLY
# These env vars are no longer the formal long-term architecture.
# Object storage is now driven by project-level bindings in the database.
# COS_* env vars are retained only for backward-compatible fallback
# when no explicit config is provided.
# COS_SECRET_ID=
# COS_SECRET_KEY=
# COS_BUCKET=
# COS_REGION=
# COS_SIGN_EXPIRES_SECONDS=900

# Per-project per-environment COS config (used by seed-projects.ts)
# INFOV_DEV_COS_BUCKET=
# INFOV_DEV_COS_REGION=
# INFOV_DEV_COS_SECRET_ID=
# INFOV_DEV_COS_SECRET_KEY=
# INFOV_PRD_COS_BUCKET=
# INFOV_PRD_COS_REGION=
# INFOV_PRD_COS_SECRET_ID=
# INFOV_PRD_COS_SECRET_KEY=
# LAICAI_DEV_COS_BUCKET=
# LAICAI_DEV_COS_REGION=
# LAICAI_DEV_COS_SECRET_ID=
# LAICAI_DEV_COS_SECRET_KEY=
# LAICAI_PRD_COS_BUCKET=
# LAICAI_PRD_COS_REGION=
# LAICAI_PRD_COS_SECRET_ID=
# LAICAI_PRD_COS_SECRET_KEY=
